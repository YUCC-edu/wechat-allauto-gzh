{
  "name": "wechat-allauto-gzh",
  "display_name": "微信公众号智能排版",
  "description": "将 Markdown 转换为精美微信公众号文章，支持多种主题、自动排版、草稿箱管理、发布能力",
  "version": "2.0.0",
  "schema_version": "1.0",
  "author": "OpenClaw Team",
  "license": "MIT",
  "icon": "📝",
  "category": "content",
  "tags": [
    "wechat",
    "weixin",
    "markdown",
    "html",
    "formatter",
    "排版",
    "publish",
    "发布",
    "draft",
    "草稿"
  ],
  "entry_points": {
    "formatter": {
      "function": "wechat_formatter_skill:convert_markdown_to_wechat_html",
      "description": "将 Markdown 文本转换为微信公众号 HTML",
      "inputs": {
        "markdown_content": {
          "type": "string",
          "description": "Markdown 格式的文本内容",
          "required": true
        },
        "theme_name": {
          "type": "string",
          "description": "主题名称，如 default、wenyan/default、macaron/pink",
          "required": false,
          "default": "default"
        },
        "themes_dir": {
          "type": "string",
          "description": "主题目录路径",
          "required": false,
          "default": "./themes"
        }
      },
      "outputs": {
        "html": {
          "type": "string",
          "description": "转换后的微信公众号 HTML"
        }
      }
    },
    "capability": {
      "function": "wechat_capability_skill:wechat_manage_capability",
      "description": "微信公众号能力管理统一接口，支持菜单、草稿、发布、素材、用户、留言等管理",
      "inputs": {
        "app_id": {
          "type": "string",
          "description": "微信公众号 AppID",
          "required": true
        },
        "app_secret": {
          "type": "string",
          "description": "微信公众号 AppSecret",
          "required": true
        },
        "capability": {
          "type": "string",
          "description": "能力模块，可选值：menu、draft、publish、material、user、comment、message、kf、analysis",
          "required": true,
          "enum": ["menu", "draft", "publish", "material", "user", "comment", "message", "kf", "analysis"]
        },
        "action": {
          "type": "string",
          "description": "执行的动作，如 create、get、delete、add、update、list 等",
          "required": true
        }
      },
      "outputs": {
        "result": {
          "type": "object",
          "description": "微信 API 的响应结果"
        }
      }
    }
  },
  "permissions": {
    "network": true,
    "file_system": true,
    "environment": ["WECHAT_APP_ID", "WECHAT_APP_SECRET"]
  },
  "dependencies": {
    "python": ">=3.8",
    "packages": [
      "requests>=2.28.0",
      "pyyaml>=6.0",
      "markdown>=3.4.0",
      "beautifulsoup4>=4.11.0"
    ]
  },
  "documentation": {
    "readme": "skill.md",
    "changelog": "CHANGELOG.md"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw-team/wechat-allauto-gzh"
  },
  "bugs": {
    "url": "https://github.com/openclaw-team/wechat-allauto-gzh/issues"
  },
  "homepage": "https://github.com/openclaw-team/wechat-allauto-gzh#readme",
  "requestFramePermissions": []
}